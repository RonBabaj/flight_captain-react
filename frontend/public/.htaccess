# SPA fallback: serve index.html for client-side routes so refresh/back don't 404.
# Hostinger / Apache compatible.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # If the request is for an existing file, serve it.
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteRule ^ - [L]

  # If the request is for an existing directory, serve it.
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Otherwise rewrite to index.html (SPA root).
  RewriteRule ^ /index.html [L]
</IfModule>
