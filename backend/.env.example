# ──────────────────────────────────────────────────────────────────────────────
# Flight Captain Web — Backend Environment Variables
# Copy this file to .env and fill in your keys.
# ──────────────────────────────────────────────────────────────────────────────

# ─── Server ───────────────────────────────────────────────────────────────────
# Port the backend listens on (defaults to 8080 if not set)
PORT=8080

# ─── Amadeus API (primary flight search provider) ────────────────────────────
# Sign up at https://developers.amadeus.com to get your API credentials.
# These power the core flight search, offers, and monthly deals endpoints.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# ─── Duffel API (optional, additional flight provider) ───────────────────────
# Sign up at https://duffel.com/docs/api to get an API key.
# When set, Duffel results are merged with Amadeus for broader coverage.
DUFFEL_API_KEY=

# ─── Google Flights via RapidAPI (optional, additional flight provider) ──────
# Subscribe to the "Google Flights2" API on https://rapidapi.com to get a key.
# Adds Google-powered flight prices alongside Amadeus/Duffel.
# Uses a 5 req/min rate limit and 10-minute cache by default.
GOOGLEFLIGHTS2_ENABLED=false
GOOGLEFLIGHTS2_RAPIDAPI_KEY=
GOOGLEFLIGHTS2_RAPIDAPI_HOST=google-flights2.p.rapidapi.com
# GOOGLEFLIGHTS2_ENDPOINT_PATH=        # Override the API path (advanced, rarely needed)

# ─── Booking link mode ───────────────────────────────────────────────────────
# Controls how outbound booking URLs are generated.
# Options: "skyscanner" (default) | "direct" (link to airline sites directly)
# BOOKING_LINK_MODE=skyscanner

# ─── Affiliate tracking (optional) ──────────────────────────────────────────
# Used in outbound booking links for commission tracking.
# Set AFFILIATE_ID for a default; use per-provider overrides as needed.
# Do NOT commit real affiliate IDs to source control.
AFFILIATE_ID=
# AFF_ID_OTA=
# AFF_ID_LY=
# AFF_ID_UA=
# AFF_ID_AA=
# AFF_ID_BA=
# AFF_ID_LH=
# AFF_ID_TK=
# AFF_ID_EK=
# AFF_ID_DL=

# ─── Telegram bot (optional) ─────────────────────────────────────────────────
# If set, enables the Telegram bot interface for flight searches.
# Create a bot via https://t.me/BotFather to get a token.
# TELEGRAM_BOT_TOKEN=
