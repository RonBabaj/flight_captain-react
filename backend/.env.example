# Amadeus API (required for flight search and deals)
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=

# Affiliate tracking (optional). Used in outbound booking links for commission tracking.
# Do not commit real affiliate IDs. Set AFFILIATE_ID for a default; use per-provider for overrides.
AFFILIATE_ID=
# AFF_ID_OTA=
# AFF_ID_LY=
# AFF_ID_UA=
# AFF_ID_AA=
# AFF_ID_BA=
# AFF_ID_LH=
# AFF_ID_TK=
# AFF_ID_EK=
# AFF_ID_DL=

# Google Flights2 (optional). RapidAPI DataCrawler - adds Google-powered flight prices.
# Set GOOGLEFLIGHTS2_ENABLED=true to enable. Uses 5 req/min rate limit and 10min cache.
GOOGLEFLIGHTS2_ENABLED=false
GOOGLEFLIGHTS2_RAPIDAPI_KEY=
GOOGLEFLIGHTS2_RAPIDAPI_HOST=google-flights2.p.rapidapi.com
